{
  "name": "tamriel-calendar",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint:ts": "vue-tsc --noEmit",
    "lint:js": "eslint .",
    "lint:js:fix": "npm run lint:js -- --fix",
    "lint:css": "stylelint **/*{.scss,.vue}",
    "lint:css:fix": "npm run lint:css -- --fix",
    "lint:all": "npm run lint:ts && npm run lint:js && npm run lint:css",
    "localazy:download": "localazy download && npm run lint:js:fix"
  },
  "dependencies": {
    "@unhead/vue": "^2.1.12",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vueuse/core": "^14.2.1",
    "dayjs": "^1.11.20",
    "v-wave": "^3.0.4",
    "vite": "~7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.4",
    "workbox-window": "^7.4.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@localazy/cli": "^2.0.8",
    "@stylistic/stylelint-config": "^4.0.0",
    "@tabler/icons-vue": "^3.40.0",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "sass-embedded": "^1.98.0",
    "stylelint": "^17.5.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-declaration-block-no-ignored-properties": "^3.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-rem-over-px": "^1.0.2",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.6"
  },
  "pnpm": {
    "overrides": {
      "is-core-module": "npm:@nolyfill/is-core-module@^1",
      "safe-buffer": "npm:@nolyfill/safe-buffer@^1",
      "string.prototype.matchall": "npm:@nolyfill/string.prototype.matchall@^1"
    }
  }
}
