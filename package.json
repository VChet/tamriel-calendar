{
  "name": "tamriel-calendar",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "preinstall": "npx -y only-allow pnpm",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite build && vite preview",
    "lint:ts": "vue-tsc",
    "lint:js": "eslint .",
    "lint:js:fix": "npm run lint:js -- --fix",
    "lint:css": "stylelint **/*{.scss,.vue}",
    "lint:css:fix": "npm run lint:css -- --fix",
    "lint:all": "npm run lint:ts && npm run lint:js && npm run lint:css",
    "localazy:download": "localazy download && npm run lint:js:fix"
  },
  "dependencies": {
    "@unhead/vue": "^3.1.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vueuse/core": "^14.2.1",
    "dayjs": "^1.11.20",
    "v-wave": "^3.0.4",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0",
    "vue": "^3.5.33",
    "vue-i18n": "^11.4.0",
    "vue-router": "^5.0.6",
    "workbox-window": "^7.4.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@localazy/cli": "^2.0.8",
    "@stylistic/stylelint-config": "^5.0.0",
    "@tabler/icons-vue": "^3.41.1",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "named-port": "^4.0.1",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "sass-embedded": "^1.99.0",
    "stylelint": "^17.9.1",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-declaration-block-no-ignored-properties": "^3.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-rem-over-px": "^1.0.2",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.2.7"
  },
  "pnpm": {
    "overrides": {
      "is-core-module": "npm:@nolyfill/is-core-module@^1",
      "safe-buffer": "npm:@nolyfill/safe-buffer@^1",
      "serialize-javascript@<7.0.5": ">=7.0.5",
      "serialize-javascript@<=7.0.2": ">=7.0.3",
      "string.prototype.matchall": "npm:@nolyfill/string.prototype.matchall@^1",
      "vite-plugin-pwa>vite": "$vite"
    }
  }
}
